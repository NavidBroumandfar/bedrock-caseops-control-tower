# Environment — Bedrock CaseOps Control Tower
# Copy to .env and fill in your values. Never commit .env to version control.

# ── General ───────────────────────────────────────────────────────────────────
APP_ENV=development                   # development | staging | production
LOG_LEVEL=INFO                        # DEBUG | INFO | WARNING | ERROR
OUTPUT_DIR=outputs                    # relative to project root

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
# AWS credentials should be managed via ~/.aws/credentials or IAM roles.
# Do not hardcode access keys here.

# ── S3 ────────────────────────────────────────────────────────────────────────
S3_DOCUMENT_BUCKET=your-caseops-documents-bucket
S3_OUTPUT_BUCKET=your-caseops-outputs-bucket   # can be same bucket with prefix

# ── Bedrock ───────────────────────────────────────────────────────────────────
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
BEDROCK_KB_ID=your-knowledge-base-id

# ── Pipeline ──────────────────────────────────────────────────────────────────
RETRIEVAL_MAX_RESULTS=5
ESCALATION_CONFIDENCE_THRESHOLD=0.60   # cases below this score are auto-escalated
MAX_AGENT_RETRIES=2

# ── CloudWatch ────────────────────────────────────────────────────────────────
CLOUDWATCH_LOG_GROUP=/caseops/pipeline
