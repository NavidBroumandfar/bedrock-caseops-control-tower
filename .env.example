# Environment — Bedrock CaseOps Control Tower
# Copy to .env and fill in your values. Never commit .env to version control.

# ── General ───────────────────────────────────────────────────────────────────
APP_ENV=development                   # development | staging | production
LOG_LEVEL=INFO                        # DEBUG | INFO | WARNING | ERROR
OUTPUT_DIR=outputs                    # relative to project root

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
# AWS credentials should be managed via ~/.aws/credentials or IAM roles.
# Do not hardcode access keys here.

# ── S3 ────────────────────────────────────────────────────────────────────────
S3_DOCUMENT_BUCKET=your-caseops-documents-bucket
S3_OUTPUT_BUCKET=your-caseops-outputs-bucket   # can be same bucket with prefix

# ── Bedrock ───────────────────────────────────────────────────────────────────
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
BEDROCK_KB_ID=your-knowledge-base-id

# ── Pipeline ──────────────────────────────────────────────────────────────────
RETRIEVAL_MAX_RESULTS=5
ESCALATION_CONFIDENCE_THRESHOLD=0.60   # cases below this score are auto-escalated
MAX_AGENT_RETRIES=2

# ── Observability / Logging (E-0) ─────────────────────────────────────────────
# Log level for the CaseOps structured logger (overrides LOG_LEVEL for pipeline logs)
CASEOPS_LOG_LEVEL=INFO                        # DEBUG | INFO | WARNING | ERROR

# Write a session log file to outputs/logs/{session_id}.log (development default: true)
CASEOPS_ENABLE_LOCAL_FILE_LOG=true

# Emit structured logs to Amazon CloudWatch Logs (disabled by default for local dev)
CASEOPS_ENABLE_CLOUDWATCH=false

# CloudWatch log group name (used when CASEOPS_ENABLE_CLOUDWATCH=true)
CASEOPS_CLOUDWATCH_LOG_GROUP=/caseops/pipeline

# Prefix for CloudWatch log stream names; streams are named {prefix}/{session_id}
CASEOPS_CLOUDWATCH_LOG_STREAM_PREFIX=caseops-session

# ── CloudWatch (legacy key — kept for backward compatibility) ──────────────────
CLOUDWATCH_LOG_GROUP=/caseops/pipeline

# ── Bedrock Guardrails (H-1) ───────────────────────────────────────────────────
# Enable the Guardrails integration layer (disabled by default; no live AWS needed locally)
CASEOPS_ENABLE_GUARDRAILS=false

# Bedrock Guardrail identifier (required when CASEOPS_ENABLE_GUARDRAILS=true)
CASEOPS_GUARDRAIL_ID=your-guardrail-id

# Guardrail version to apply (use "DRAFT" for unpublished versions)
CASEOPS_GUARDRAIL_VERSION=1

# Attach raw Guardrail assessment trace to normalized results (default: false)
CASEOPS_GUARDRAIL_TRACE=false

# ── Prompt Caching (I-0) ───────────────────────────────────────────────────────
# Enable Bedrock prompt caching for system prompts (disabled by default).
# When enabled, a cachePoint marker is injected into the Converse system block
# so repeated calls with identical system prompts benefit from server-side
# caching.  Requires a caching-eligible model (e.g. Claude 3.5 Sonnet or later).
CASEOPS_ENABLE_PROMPT_CACHING=false

# Cache the system prompt block (default: true when caching is enabled).
# Set to false to disable system-prompt caching while keeping the feature on.
CASEOPS_CACHE_SYSTEM_PROMPT=true

# Minimum token count for a block to be eligible for caching (Bedrock enforces
# a 1024-token minimum server-side; this value is informational and validated
# at startup).
CASEOPS_MIN_CACHEABLE_TOKENS=1024

# Maximum number of cachePoint markers injected per request (1–4; default 1).
# I-0 only uses the system block, so 1 is the effective ceiling today.
CASEOPS_MAX_CACHE_CHECKPOINTS=1
